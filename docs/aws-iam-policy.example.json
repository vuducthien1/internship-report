{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "VdcmsPrivateStorage",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::YOUR_VDCMS_BUCKET"
    },
    {
      "Sid": "VdcmsPrivateObjects",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::YOUR_VDCMS_BUCKET/*"
    },
    {
      "Sid": "VdcmsEmail",
      "Effect": "Allow",
      "Action": ["ses:SendEmail", "ses:GetAccount"],
      "Resource": "*"
    },
    {
      "Sid": "VdcmsTranscribe",
      "Effect": "Allow",
      "Action": ["transcribe:StartTranscriptionJob", "transcribe:GetTranscriptionJob", "transcribe:ListTranscriptionJobs"],
      "Resource": "*"
    },
    {
      "Sid": "PassTranscribeDataRole",
      "Effect": "Allow",
      "Action": ["iam:PassRole"],
      "Resource": "YOUR_TRANSCRIBE_DATA_ROLE_ARN"
    }
  ]
}
