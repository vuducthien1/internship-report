PORT=5000
DB_HOST=127.0.0.1
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=smart_construction_db
JWT_SECRET=replace_with_a_long_random_secret
CORS_ORIGINS=http://localhost:5173
APP_URL=http://localhost:5173
NODE_ENV=development
# Optional: configure Resend to deliver verification and password-reset emails.
RESEND_API_KEY=
EMAIL_FROM=VDCMS <onboarding@resend.dev>

# AWS integration (optional). Prefer an IAM role in production; never commit real access keys.
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_S3_BUCKET=
AWS_SES_FROM_EMAIL=
AWS_TRANSCRIBE_ENABLED=false
AWS_TRANSCRIBE_ROLE_ARN=
AWS_TRANSCRIBE_TIMEOUT_SECONDS=90
